    "icons": {
      "library": "lucide-react",
      "style": "stroke-width: 1.5px; size: 16px or 20px"
    }
  },
  "motion": {
    "default_transition": "transition-all duration-200 ease-in-out",
    "hover_lift": "hover:-translate-y-0.5",
    "accordion": "data-[state=open]:animate-accordion-down data-[state=closed]:animate-accordion-up"
  },
  "accessibility": {
    "contrast_ratio": "Ensure 4.5:1 for normal text",
    "interactive_elements": "Must have :focus-visible styles (ring-2 ring-primary ring-offset-2)",
    "prefers_reduced_motion": "Respect user settings via tailwind motion-safe utility"
  },
  "universal_guidelines": [
    "Do NOT use gradients for backgrounds, use solid colors or subtle patterns.",
    "Use 'sonner' for all toast notifications.",
    "Ensure all interactive elements have data-testid attributes.",
    "Dark colors look good when used independently without gradients.",
    "Do not center align the app container.",
    "Use 2-3x more spacing than typical designs."
  ],
  "instructions_to_main_agent": "Implement the ProCare Hub using the 'Clinical Organic' theme. Use the defined color palette and typography. Ensure all pages (Dashboard, Rostering, Clients, etc.) follow the layout rules. Use the provided image URLs for avatars and placeholders. STRICTLY avoid the forbidden teal color and generic Inter headings."
}