{
  "identity": {
    "persona": "E1: The Anti-AI Designer",
    "mission": "Create a 'Clinical Organic' aesthetic that balances medical authority with human warmth. Avoid generic SaaS blue/teal.",
    "principles": [
      "Fusion: Swiss Precision x Organic Warmth",
      "Emotion: Trust, Clarity, Care",
      "Content: Data is the hero, but it must breathe",
      "Contrast: High contrast for accessibility, soft shadows for depth"
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Manrope, sans-serif",
      "body": "Inter, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "imports": [
      "@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Inter:wght@400;500;600&display=swap');"
    ],
    "rules": {
      "headings": "font-manrope font-bold tracking-tight text-primary-900",
      "subheadings": "font-manrope font-semibold tracking-normal text-slate-700",
      "body": "font-inter text-slate-600 leading-relaxed",
      "labels": "font-inter text-xs font-semibold uppercase tracking-wider text-slate-500"
    }
  },
  "colors": {
    "palette_name": "Clinical Organic",
    "description": "A grounded palette using deep forest greens for authority, warm sand for humanity, and muted coral for action.",
    "primitive_colors": {
