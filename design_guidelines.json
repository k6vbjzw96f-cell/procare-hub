        "200": "#ebebe3",
        "300": "#dad9cd",
        "400": "#bfbead",
        "500": "#a4a28d",
        "600": "#84826f",
        "700": "#6b6959",
        "800": "#58574a",
        "900": "#49483e",
        "950": "#262620"
      },
      "coral": {
        "50": "#fef4f1",
        "100": "#ffe6df",
        "200": "#ffd0c3",
        "300": "#ffaf9b",
        "400": "#fc8266",
        "500": "#f25a38",
        "600": "#e03e1f",
        "700": "#bc2f15",
        "800": "#9b2915",
        "900": "#7e2616",
        "950": "#441006"
      }
    },
    "semantic_tokens": {
      "background": "#F8FAFC",
      "foreground": "#1E293B",
      "card": "#FFFFFF",
      "card_foreground": "#1E293B",
      "primary": "#184536",
      "primary_foreground": "#FFFFFF",
      "secondary": "#F5F5F0",
      "secondary_foreground": "#184536",
      "muted": "#F1F5F9",
      "muted_foreground": "#64748B",
      "accent": "#f2fcf5",
      "accent_foreground": "#184536",
      "destructive": "#EF4444",
      "destructive_foreground": "#FFFFFF",
      "border": "#E2E8F0",
      "input": "#E2E8F0",
      "ring": "#184536"
    }
  },
  "layout": {
    "spacing_scale": "Tailwind (p-1 to p-32)",
    "container_padding": "p-6 md:p-8 lg:p-12",
    "grid_system": {
      "dashboard": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6",
      "form": "grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6"
    },
    "border_radius": {
      "card": "rounded-xl",
      "button": "rounded-lg",
      "input": "rounded-lg"
    }
  },
  "components": {
    "Shadcn": {
      "Button": {
        "default": "bg-primary text-white hover:bg-primary/90 shadow-sm font-medium",
        "outline": "border-2 border-primary/20 bg-transparent hover:bg-primary/5 text-primary",
        "ghost": "hover:bg-primary/5 text-primary-700"
      },
      "Card": {
        "style": "bg-white border border-slate-100 shadow-[0_2px_8px_rgba(0,0,0,0.04)] hover:shadow-[0_4px_12px_rgba(0,0,0,0.06)] transition-all duration-300"
      },
      "Input": {
        "style": "bg-white border-slate-200 focus:border-primary focus:ring-primary/20 h-11"
      },
      "Table": {
        "style": "w-full text-sm",
        "header": "bg-slate-50/50 text-slate-500 font-medium uppercase tracking-wider text-xs h-12",
        "row": "border-b border-slate-100 hover:bg-slate-50/50 transition-colors"
      }
    },
    "Custom": {
      "StatCard": "p-6 bg-white rounded-xl border border-slate-100 shadow-sm flex flex-col gap-2 relative overflow-hidden",
      "StatusBadge": {
        "success": "bg-emerald-50 text-emerald-700 border border-emerald-100 px-2.5 py-0.5 rounded-full text-xs font-medium",
        "warning": "bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-0.5 rounded-full text-xs font-medium",
        "error": "bg-rose-50 text-rose-700 border border-rose-100 px-2.5 py-0.5 rounded-full text-xs font-medium",
        "neutral": "bg-slate-100 text-slate-700 border border-slate-200 px-2.5 py-0.5 rounded-full text-xs font-medium"
      }
    }
  },
